{
    "name": "cboxdk/laravel-telemetry",
    "description": "Collector-free telemetry for Laravel: Prometheus metrics, OTLP traces and events. No C extension, no protobuf, no sidecar — metrics that actually work under FPM.",
    "keywords": [
        "cbox",
        "laravel",
        "telemetry",
        "observability",
        "metrics",
        "tracing",
        "prometheus",
        "opentelemetry",
        "otlp"
    ],
    "homepage": "https://github.com/cboxdk/laravel-telemetry",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/cboxdk/laravel-telemetry/issues",
        "source": "https://github.com/cboxdk/laravel-telemetry"
    },
    "authors": [
        {
            "name": "Sylvester Damgaard",
            "email": "sn@cbox.dk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4|^8.5",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "cboxdk/system-metrics": "^3.0",
        "larastan/larastan": "^3.0",
        "laravel/horizon": "^5.47",
        "laravel/pennant": "^1.24",
        "laravel/pint": "^1.14",
        "laravel/reverb": "^1.10",
        "livewire/livewire": "^3.0|^4.0",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "suggest": {
        "ext-apcu": "Required when using the apcu metric store.",
        "ext-redis": "Recommended when using the redis metric store (phpredis).",
        "ext-excimer": "CPU profiling for slow requests/jobs (telemetry.instrument.profiling) — a 'top functions by sample count' event, not a full pprof export.",
        "cboxdk/system-metrics": "Host CPU/memory/load metrics via the built-in provider AND real per-request/per-job process footprint (peak RSS, CPU utilization) on spans.",
        "geoip2/geoip2": "Resolve client.geo.* from the IP for analytics (telemetry.analytics.geo) with a MaxMind GeoLite2 database, so the raw IP can be dropped.",
        "laravel/horizon": "Supervisor/master state, long-wait detection, process restarts and OOM metrics when Horizon runs your queues.",
        "laravel/reverb": "WebSocket message/channel/connection metrics when Reverb is your broadcasting server.",
        "laravel/pennant": "Feature flag check counters (feature.checks, feature.unknown).",
        "livewire/livewire": "Component lifecycle: mount/hydrate counters + render/update/call detail spans."
    },
    "autoload": {
        "psr-4": {
            "Cbox\\Telemetry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cbox\\Telemetry\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cbox\\Telemetry\\TelemetryServiceProvider"
            ],
            "aliases": {
                "Telemetry": "Cbox\\Telemetry\\Facades\\Telemetry"
            }
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test",
        "test": "php -d memory_limit=512M vendor/bin/pest --exclude-group=benchmark",
        "test-coverage": "vendor/bin/pest --coverage",
        "license-check": "php bin/check-licenses.php",
        "sbom": "php bin/generate-sbom.php",
        "check": [
            "@format:check",
            "@analyse",
            "@test"
        ],
        "qa": [
            "@format:check",
            "@analyse",
            "@test",
            "@license-check",
            "composer audit --no-dev"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
