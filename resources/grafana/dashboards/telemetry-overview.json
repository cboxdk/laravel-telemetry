    {
      "id": 31,
      "type": "table",
      "title": "Routes by p95 latency (ms) \u2014 click to drill down",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "Q32",
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_milliseconds_bucket{service_name=~\"$service\"}[10m])))",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "http_route"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Drill down: requests on this route",
                    "url": "/d/cbox-tel-requests/telemetry-requests?${__url_time_range}&var-service=$service&var-route=${__data.fields.http_route}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 33,
      "type": "table",
