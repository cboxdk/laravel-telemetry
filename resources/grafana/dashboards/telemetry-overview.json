{
  "uid": "cbox-tel-overview",
  "title": "Telemetry",
  "tags": [
    "telemetry",
    "cboxdk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, service_name)",
          "refId": "service"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "tags": [
        "telemetry"
      ],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "title": ""
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Activity",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / min",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "Q3",
          "expr": "sum(rate(http_server_request_duration_milliseconds_count{service_name=~\"$service\"}[5m])) * 60",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
