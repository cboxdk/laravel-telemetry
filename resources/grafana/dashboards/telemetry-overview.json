          "refId": "Q7",
          "expr": "100 * sum(rate(http_server_request_duration_milliseconds_count{service_name=~\"$service\",http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_milliseconds_count{service_name=~\"$service\"}[5m]))",
          "legendFormat": "__auto",
