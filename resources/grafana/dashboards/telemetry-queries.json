{
  "uid": "cbox-tel-queries",
  "title": "Telemetry / Queries",
  "tags": [
    "telemetry",
    "cboxdk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, service_name)",
          "refId": "service"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "minms",
        "type": "textbox",
        "label": "min query ms",
        "query": "10",
        "current": {
          "text": "10",
          "value": "10"
        },
        "options": []
      },
      {
        "name": "minqueries",
        "type": "textbox",
        "label": "min queries/request",
        "query": "25",
        "current": {
          "text": "25",
          "value": "25"
        },
        "options": []
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "tags": [
        "telemetry"
      ],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "title": ""
    }
  ],
  "panels": [
    {
      "id": 139,
      "type": "table",
      "title": "Slowest queries (> $minms ms) \u2014 SQL text on the span",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && name=\"db.query\" && duration>${minms}ms} | select(span.db.query.text, span.db.namespace)",
          "limit": 20,
          "spss": 3,
          "tableType": "spans"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 140,
      "type": "table",
      "title": "N+1 suspects \u2014 requests running \u2265 $minqueries queries",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && kind=server && span.db.query.count >= $minqueries} | select(span.db.query.count, span.db.query.time_ms)",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      },
      "description": "db.query.count/time_ms tallies live on every root span."
    },
    {
      "id": 141,
      "type": "table",
      "title": "Query-heaviest jobs",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && kind=consumer && span.db.query.count >= $minqueries} | select(span.db.query.count, span.db.query.time_ms)",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 142,
      "type": "text",
      "title": "Tip",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "options": {
        "mode": "markdown",
        "content": "Every root span carries `db.query.count` / `db.query.time_ms` tallies \u2014 even when individual query spans are filtered by `queries_min_duration` or tail mode."
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ],
  "editable": true
}