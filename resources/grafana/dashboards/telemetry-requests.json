{
  "uid": "cbox-tel-requests",
  "title": "Telemetry / Requests",
  "tags": [
    "telemetry",
    "cboxdk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, service_name)",
          "refId": "service"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "route",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, http_route)",
          "refId": "route"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "method",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, http_request_method)",
          "refId": "method"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "status",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, http_response_status_code)",
          "refId": "status"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "minms",
        "type": "textbox",
        "label": "min duration (ms)",
        "query": "0",
        "current": {
          "text": "0",
          "value": "0"
        },
        "options": []
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "tags": [
        "telemetry"
      ],
      "title": "Telemetry",
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true
    }
  ],
  "panels": [
    {
      "id": 35,
      "type": "stat",
      "title": "Requests / min",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "Q36",
          "expr": "sum(rate(http_server_request_duration_milliseconds_count{service_name=~\"$service\",http_route=~\"$route\",http_request_method=~\"$method\",http_response_status_code=~\"$status\"}[5m])) * 60",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 37,
      "type": "stat",
      "title": "p50",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "refId": "Q38",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_milliseconds_bucket{service_name=~\"$service\",http_route=~\"$route\",http_request_method=~\"$method\",http_response_status_code=~\"$status\"}[5m])))",
