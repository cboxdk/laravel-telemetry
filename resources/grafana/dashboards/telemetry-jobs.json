        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Workers self-report after every job. One line per worker process."
    },
    {
      "id": 105,
      "type": "row",
      "title": "Traces",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "panels": []
    },
    {
      "id": 106,
      "type": "table",
      "title": "Job runs \u2014 origin request in messaging.origin.name, queue lag in wait_time_ms",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && resource.deployment.environment.name=~\"$environment\" && resource.host.name=~\"$host\" && kind=consumer} | select(span.messaging.origin.name, span.messaging.wait_time_ms)",
          "limit": 20,
          "spss": 3,
          "tableType": "spans"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 107,
      "type": "table",
      "title": "Failed attempts",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && resource.deployment.environment.name=~\"$environment\" && resource.host.name=~\"$host\" && kind=consumer && status=error}",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    }
  ],
  "editable": true
}