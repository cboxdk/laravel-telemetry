    },
    {
      "id": 104,
      "type": "timeseries",
      "title": "Worker memory \u2014 a climbing line IS the leak",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "refId": "Q102",
          "expr": "worker_memory_rss_bytes{service_name=~\"$service\",deployment_environment_name=~\"$environment\",host_name=~\"$host\"}",
          "legendFormat": "rss pid {{pid}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "Q103",
          "expr": "worker_memory_php_bytes{service_name=~\"$service\",deployment_environment_name=~\"$environment\",host_name=~\"$host\"}",
          "legendFormat": "php pid {{pid}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
