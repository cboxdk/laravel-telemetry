        "x": 8,
        "y": 31
      },
      "targets": [
        {
          "refId": "Q213",
          "expr": "histogram_quantile(0.95, sum by (le, signal) (rate(telemetry_export_duration_milliseconds_bucket{service_name=~\"$service\",deployment_environment_name=~\"$environment\",host_name=~\"$host\"}[$__rate_interval])))",
          "legendFormat": "{{signal}}",
