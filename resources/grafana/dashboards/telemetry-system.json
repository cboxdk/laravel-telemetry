      },
      "targets": [
        {
          "refId": "Q218",
          "expr": "max(telemetry_spool_depth{service_name=~\"$service\",deployment_environment_name=~\"$environment\",host_name=~\"$host\"}) or vector(0)",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
