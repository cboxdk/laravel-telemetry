        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 215,
      "type": "stat",
      "title": "Circuit breaker",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 31
      },
      "targets": [
        {
          "refId": "Q216",
          "expr": "max(telemetry_export_circuit_open_ratio{service_name=~\"$service\",deployment_environment_name=~\"$environment\",host_name=~\"$host\"}) or vector(0)",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
