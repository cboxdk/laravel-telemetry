        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "description": "1 = OTLP circuit open (recent transport failure). Alert on sustained 1."
    },
    {
      "id": 217,
      "type": "stat",
      "title": "Spool depth",
      "datasource": {
        "type": "prometheus",
