{
  "uid": "cbox-tel-mail",
  "title": "Telemetry / Mail & Notifications",
  "tags": [
    "telemetry",
    "cboxdk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, service_name)",
          "refId": "service"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "tags": [
        "telemetry"
      ],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "title": ""
    }
  ],
  "panels": [
    {
      "id": 169,
      "type": "stat",
      "title": "Mail sent / h",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "Q170",
          "expr": "sum(increase(mail_sent_total{service_name=~\"$service\"}[1h]))",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 171,
      "type": "stat",
      "title": "Notifications / h",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "Q172",
          "expr": "sum(increase(notifications_sent_total{service_name=~\"$service\"}[1h]))",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 174,
      "type": "timeseries",
      "title": "Notifications by channel",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "Q173",
          "expr": "sum by (channel) (increase(notifications_sent_total{service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{channel}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "axisSoftMin": 0,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 175,
      "type": "table",
      "title": "By notification class (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "Q176",
          "expr": "sum by (notification) (increase(notifications_sent_total{service_name=~\"$service\"}[1h]))",
          "legendFormat": "__auto",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "range": false,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "auto",
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ],
        "cellHeight": "md",
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": 177,
      "type": "table",
      "title": "Send spans (mail + notifications)",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && (name=\"mail.send\" || name=\"notification.send\")}",
          "limit": 20,
          "spss": 3,
          "tableType": "spans"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    }
  ],
  "editable": true
}