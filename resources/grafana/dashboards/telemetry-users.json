{
  "uid": "cbox-tel-users",
  "title": "Telemetry / Users",
  "tags": [
    "telemetry",
    "cboxdk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, service_name)",
          "refId": "service"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "user",
        "type": "textbox",
        "label": "user id",
        "query": ".+",
        "current": {
          "text": ".+",
          "value": ".+"
        },
        "options": []
      },
      {
        "name": "minmb",
        "type": "textbox",
        "label": "min memory (MB)",
        "query": "64",
        "current": {
          "text": "64",
          "value": "64"
        },
        "options": []
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "tags": [
        "telemetry"
      ],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "title": ""
    }
  ],
  "panels": [
    {
      "id": 198,
      "type": "table",
      "title": "Requests for user $user",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && kind=server && span.enduser.id=~\"$user\"}",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 199,
      "type": "table",
      "title": "Errors hit by user $user",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && span.enduser.id=~\"$user\" && status=error}",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 200,
      "type": "table",
      "title": "Memory hogs (> $minmb MB)",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && kind=server && span.php.memory.peak_bytes > $minmb000000}",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 201,
      "type": "text",
      "title": "Tip",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "options": {
        "mode": "markdown",
        "content": "Request spans carry `enduser.id` (opt-out: `TELEMETRY_INSTRUMENT_USER=false`). Enrich with names via `Telemetry::resolveUserUsing()` \u2014 explicit PII opt-in."
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ],
  "editable": true
}