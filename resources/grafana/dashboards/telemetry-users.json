{
  "uid": "cbox-tel-users",
  "title": "Telemetry / Users",
  "tags": [
    "telemetry",
    "cboxdk"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "hide": false,
        "iconColor": "purple",
        "expr": "{service_name=~\"$service\"} |= `app.deployment`",
        "titleFormat": "Deploy"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, service_name)",
          "refId": "service"
        },
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "environment",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, deployment_environment_name)",
          "refId": "environment"
        },
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(http_server_request_duration_milliseconds_count, host_name)",
          "refId": "host"
        },
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "user",
        "type": "textbox",
        "label": "user id",
        "query": ".+",
        "current": {
          "text": ".+",
          "value": ".+"
        },
        "options": []
      },
      {
        "name": "usertype",
        "type": "textbox",
        "label": "user type",
        "query": ".+",
        "current": {
          "text": ".+",
          "value": ".+"
        },
        "options": []
      },
      {
        "name": "sessionhash",
        "type": "textbox",
        "label": "session hash",
        "query": ".+",
        "current": {
          "text": ".+",
          "value": ".+"
        },
        "options": []
      },
      {
        "name": "minmb",
        "type": "textbox",
        "label": "min memory (MB)",
        "query": "64",
        "current": {
          "text": "64",
          "value": "64"
        },
        "options": []
      }
    ]
  },
  "links": [
    {
      "type": "dashboards",
      "tags": [
        "telemetry"
      ],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "title": ""
    }
  ],
  "panels": [
    {
      "id": 219,
      "type": "table",
      "title": "Requests for user $user ($usertype)",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && resource.deployment.environment.name=~\"$environment\" && resource.host.name=~\"$host\" && kind=server && span.enduser.id=~\"$user\" && span.enduser.type=~\"$usertype\"} | select(span.enduser.type, span.enduser.guard)",
          "limit": 20,
          "spss": 3,
          "tableType": "spans"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 220,
      "type": "table",
      "title": "Errors hit by user $user ($usertype)",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && resource.deployment.environment.name=~\"$environment\" && resource.host.name=~\"$host\" && span.enduser.id=~\"$user\" && span.enduser.type=~\"$usertype\" && status=error}",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 221,
      "type": "table",
      "title": "Session journey \u2014 every request in visit $sessionhash",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && resource.deployment.environment.name=~\"$environment\" && resource.host.name=~\"$host\" && kind=server && span.session.hash=~\"$sessionhash\"} | select(span.enduser.id, span.session.hash)",
          "limit": 20,
          "spss": 3,
          "tableType": "spans"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      },
      "description": "session.hash from any request span follows the visitor across requests \u2014 the anonymous-user story enduser.id can't tell."
    },
    {
      "id": 222,
      "type": "table",
      "title": "Memory hogs (> $minmb MB)",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && resource.deployment.environment.name=~\"$environment\" && resource.host.name=~\"$host\" && kind=server && span.php.memory.peak_bytes > $minmb000000}",
          "limit": 20,
          "spss": 3,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm"
      }
    },
    {
      "id": 223,
      "type": "text",
      "title": "Tip",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "options": {
        "mode": "markdown",
        "content": "Request spans carry `enduser.id`, `enduser.type` (the model: user/admin/reseller) and `enduser.guard` \u2014 multi-guard apps never mix up admin #7 and user #7. Opt-out: `TELEMETRY_INSTRUMENT_USER=false`. Enrich via `Telemetry::resolveUserUsing(fn ($user, $guard) => [...])` \u2014 explicit PII opt-in."
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ],
  "editable": true
}