    {
      "id": 81,
      "type": "table",
      "title": "Job runs (consumer spans) \u2014 origin request in messaging.origin.name",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && kind=consumer}",
          "limit": 20,
          "spss": 3,
          "tableType": "spans"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 82,
